# 阿尔兹海默症诊断系统 - 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# 数据库配置
DATABASE_URL=sqlite:///./alzheimer.db

# 生产环境建议使用PostgreSQL:
# DATABASE_URL=postgresql://alzheimer_user:your_secure_password@db:5432/alzheimer_diagnostic

# 应用配置
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=false
LOG_LEVEL=INFO

# 服务器配置
HOST=0.0.0.0
PORT=8888
WORKERS=4
TIMEOUT=120

# 上传文件配置
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.nii,.nii.gz,.dcm

# JWT认证配置
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# 邮件配置（可选）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=alzheimer-system@example.com

# Redis缓存配置（可选）
REDIS_URL=redis://:your-redis-password@redis:6379/0

# 对象存储配置（可选，用于存储大型MRI文件）
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BUCKET_NAME=alzheimer-diagnostic-files

# Docker配置
DOCKER_IMAGE_NAME=alzheimer-diagnostic-system
DOCKER_CONTAINER_NAME=alzheimer-app
DOCKER_RESTART_POLICY=unless-stopped

# 备份配置
BACKUP_ENABLED=true
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=30

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090